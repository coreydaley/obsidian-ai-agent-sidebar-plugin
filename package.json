{
  "name": "obsidian-ai-agent-sidebar",
  "version": "0.2.1",
  "description": "Obsidian plugin that adds an AI agent chat sidebar with vault CRUD capabilities",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "ai",
    "plugin",
    "claude",
    "codex",
    "gemini",
    "copilot"
  ],
  "author": "Corey Daley",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.27.3",
    "obsidian": "latest",
    "tslib": "^2.4.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.37.0",
    "@google/generative-ai": "0.24.0",
    "openai": "4.85.4"
  }
}
