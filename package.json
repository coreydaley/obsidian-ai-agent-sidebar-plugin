{
  "name": "obsidian-ai-agent-sidebar",
  "version": "1.0.0",
  "description": "Obsidian plugin that adds an AI agent chat sidebar with vault CRUD capabilities",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "ai", "plugin", "claude", "codex", "gemini", "copilot"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.3",
    "obsidian": "latest",
    "tslib": "^2.4.0",
    "typescript": "^5.0.4"
  }
}
